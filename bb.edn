{:paths ["src"]
 :tasks
 {evaluate {:doc "Evaluate a job description against your CV"
            :task (do (require 'career-ops.core)
                      (apply (resolve 'career-ops.core/-main) "evaluate" *command-line-args*))}
  pdf      {:doc "Generate a tailored PDF resume from Typst template"
            :task (do (require 'career-ops.core)
                      (apply (resolve 'career-ops.core/-main) "pdf" *command-line-args*))}
  tracker  {:doc "Display or update current pipeline status"
            :task (do (require 'career-ops.core)
                      (apply (resolve 'career-ops.core/-main) "tracker" *command-line-args*))}}}
