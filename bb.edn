 {:paths ["src"]
  :tasks
  {profile  {:doc "Extract Master Profile & STAR Stories from raw data"
             :task (do (require 'career-ops.core)
                       (apply (resolve 'career-ops.core/-main) "profile" *command-line-args*))}
   evaluate {:doc "Evaluate a job description against your CV using 3-stage MAS"
             :task (do (require 'career-ops.core)
                       (apply (resolve 'career-ops.core/-main) "evaluate" *command-line-args*))}
   interview {:doc "Generate Interview Prep Sheet based on STAR Stories"
              :task (do (require 'career-ops.core)
                        (apply (resolve 'career-ops.core/-main) "interview" *command-line-args*))}
   pdf      {:doc "Generate a tailored PDF resume from Typst template"
             :task (do (require 'career-ops.core)
                       (apply (resolve 'career-ops.core/-main) "pdf" *command-line-args*))}
   tracker  {:doc "Display or update current pipeline status"
             :task (do (require 'career-ops.core)
                       (apply (resolve 'career-ops.core/-main) "tracker" *command-line-args*))}}}
